# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# OPENAI_API_KEY: server-side key used by server.js to mint ephemeral
# Realtime API client_secrets. Browsers never see this key — they only
# see the short-lived ephemeral tokens.
#
# Local dev:        cp .env.example .env  &&  edit  &&  node --env-file=.env server.js
# Railway:          set via dashboard, no .env needed in production.
# Vercel:           NOT required — only the WS/token server needs it.

OPENAI_API_KEY=sk-proj-replace-me
